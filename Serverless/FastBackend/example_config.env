# FastBackend Example Configuration
# Copy this to config.env and update with your values

# 🔑 RunPod API Key (Get from: https://www.runpod.io/console/user/settings)
RUNPOD_API_KEY=xxxxxx-xxxxxxxxx-xxxxxxxxx-xxxxxxxxx

# 🐙 GitHub Configuration (Required for auto-updates)
GITHUB_USERNAME=your_github_username
GITHUB_REPO=runpod-lora-fast

# 🤗 HuggingFace Token (Optional - for gated models)
HF_TOKEN=your_huggingface_token_here

# 📁 Workspace Paths (Default values)
WORKSPACE_PATH=/workspace
MODELS_PATH=/workspace/models
TRAINING_DATA_PATH=/workspace/training_data

# ⚙️ RunPod Settings
RUNPOD_GPU_TYPE=NVIDIA GeForce RTX 4090
RUNPOD_REGION=EU-SE-1
RUNPOD_CONTAINER_DISK_GB=50
RUNPOD_VOLUME_GB=100

# 🚀 Performance Settings
PYTORCH_CUDA_ALLOC_CONF=max_split_size_mb:512
HF_HUB_ENABLE_HF_TRANSFER=1
TRANSFORMERS_CACHE=/workspace/cache

# 🐳 Docker Settings
DOCKER_IMAGE=runpod/pytorch:2.1.0-py3.10-cuda11.8.0-devel-ubuntu22.04

# 📊 Logging
LOG_LEVEL=INFO
PYTHONUNBUFFERED=1
PYTHONDONTWRITEBYTECODE=1