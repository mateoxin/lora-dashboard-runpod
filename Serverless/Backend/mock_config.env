# Mock Environment for Local Testing
# Copy this to .env to test backend without external dependencies

# 🧪 MOCK MODE - Enable fake services
MOCK_MODE=true
DEBUG=true

# API Settings
HOST=0.0.0.0
PORT=8000

# GPU Settings (not used in mock mode but required)
MAX_CONCURRENT_JOBS=5
GPU_TIMEOUT=14400

# Redis (not used in mock mode but required)
REDIS_URL=redis://localhost:6379/0

# Storage (not used in mock mode but required)  
S3_ENDPOINT_URL=https://storage.runpod.io
S3_ACCESS_KEY=mock_access_key
S3_SECRET_KEY=mock_secret_key
S3_BUCKET=mock-bucket
S3_REGION=us-east-1

# File Paths (not used in mock mode)
WORKSPACE_PATH=/workspace
MODELS_PATH=/workspace/models
OUTPUT_PATH=/workspace/output
LOGS_PATH=/workspace/logs 