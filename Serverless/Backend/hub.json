{
  "title": "LoRA Dashboard Backend - Training & Generation Suite",
  "description": "Production-ready serverless backend for LoRA model training and FLUX image generation with dual-mode architecture (FastAPI + RunPod Serverless)",
  "type": "serverless",
  "category": "ai-training",
  "iconUrl": "https://raw.githubusercontent.com/your-repo/lora-dashboard/main/docs/icon.png",
  
  "config": {
    "runsOn": "GPU",
    "containerDiskInGb": 50,
    "gpuCount": 1,
    "gpuIds": "RTX A6000,NVIDIA A40,RTX A100,-NVIDIA RTX 4090",
    "allowedCudaVersions": ["12.1", "12.0", "11.8"],
    
    "presets": [
      {
        "name": "Production Mode",
        "defaults": {
          "MOCK_MODE": "false",
          "MAX_CONCURRENT_JOBS": "10",
          "GPU_TIMEOUT": "14400",
          "DEBUG": "false"
        }
      },
      {
        "name": "Development Mode", 
        "defaults": {
          "MOCK_MODE": "true",
          "MAX_CONCURRENT_JOBS": "5",
          "GPU_TIMEOUT": "3600",
          "DEBUG": "true"
        }
      }
    ],
    
    "env": [
      {
        "key": "MOCK_MODE",
        "input": {
          "type": "boolean",
          "name": "Mock Mode",
          "description": "Enable mock services for testing without external dependencies",
          "default": false,
          "trueValue": "true",
          "falseValue": "false"
        }
      },
      {
        "key": "S3_ENDPOINT_URL",
        "input": {
          "name": "S3 Endpoint URL",
          "type": "string",
          "description": "S3-compatible storage endpoint (e.g., https://storage.runpod.io)",
          "default": "https://storage.runpod.io"
        }
      },
      {
        "key": "S3_BUCKET",
        "input": {
          "name": "S3 Bucket Name",
          "type": "string", 
          "description": "S3 bucket for storing models and outputs",
          "default": "lora-dashboard-storage"
        }
      },
      {
        "key": "S3_ACCESS_KEY",
        "input": {
          "name": "S3 Access Key",
          "type": "string",
          "description": "S3 access key for authentication",
          "secret": true
        }
      },
      {
        "key": "S3_SECRET_KEY", 
        "input": {
          "name": "S3 Secret Key",
          "type": "string",
          "description": "S3 secret key for authentication",
          "secret": true
        }
      },
      {
        "key": "REDIS_URL",
        "input": {
          "name": "Redis URL",
          "type": "string",
          "description": "Redis connection URL for job queue management",
          "default": "redis://localhost:6379/0"
        }
      },
      {
        "key": "MAX_CONCURRENT_JOBS",
        "input": {
          "name": "Max Concurrent Jobs",
          "type": "number",
          "description": "Maximum number of concurrent training/generation jobs",
          "min": 1,
          "max": 50,
          "default": 10
        }
      },
      {
        "key": "GPU_TIMEOUT",
        "input": {
          "name": "GPU Timeout (seconds)",
          "type": "number",
          "description": "Maximum execution time for GPU jobs",
          "min": 300,
          "max": 28800,
          "default": 14400
        }
      },
      {
        "key": "DEBUG",
        "input": {
          "type": "boolean",
          "name": "Debug Mode",
          "description": "Enable detailed logging for troubleshooting",
          "default": false,
          "trueValue": "true",
          "falseValue": "false"
        }
      }
    ]
  }
} 